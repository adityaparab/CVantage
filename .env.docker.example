# CVantage - full-Docker mode (`docker compose --profile full up --build`)
# Copy to `.env.docker`. MONGODB_URI is set by compose (service-network DNS).
NODE_ENV=production
PORT=3000
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# REQUIRED in production mode - generate real values:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-to-48-random-bytes-base64-change-me!!
JWT_REFRESH_SECRET=change-me-to-48-random-bytes-base64-change-me!
COOKIE_SECRET=change-me-to-48-random-bytes-base64-change-me!!!
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=cGxlYXNlLXJlcGxhY2UtbWUtMzItYnl0ZXMtbm93ISE=

STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads

# openai | fake (fake = full demo without any key)
LLM_PROVIDER=openai
# OPENAI_API_KEY=
LLM_PARSING_MODEL=gpt-4o-mini
LLM_ANALYSIS_MODEL=gpt-4o

MAIL_DRIVER=console
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
