{
  "name": "cvantage",
  "version": "0.1.0",
  "private": true,
  "description": "CVantage — AI-powered resume analysis platform for job seekers",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityaparab/CVantage.git"
  },
  "workspaces": [
    "server",
    "frontend",
    "shared"
  ],
  "engines": {
    "node": ">=22",
    "yarn": "^1.22.0",
    "npm": "please-use-yarn"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mongodb": "^7.3.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.5"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "yarn workspaces run test",
    "build": "yarn workspaces run build",
    "dev:server": "yarn workspace @cvantage/server dev",
    "dev:frontend": "yarn workspace @cvantage/frontend dev",
    "prepare": "husky",
    "e2e:browser": "yarn build && playwright test"
  },
  "resolutions": {
    "vite": "^6.3.5"
  }
}
