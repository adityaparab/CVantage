# ============================================================================
# CVantage — environment configuration
# ============================================================================
# Copy to `.env` (repo root or server/) and adjust. Every key is validated at
# boot (server/src/config/env.validation.ts); invalid config fails fast.
# Keys commented out are OPTIONAL — the feature is flagged off when absent.
# A parity test keeps this file and the schema in lockstep.
# ============================================================================

# ----------------------------- core -----------------------------------------
# development | test | production
NODE_ENV=development
PORT=3000
# Public base URL of the app (used in links/emails/OAuth callbacks)
APP_BASE_URL=http://localhost:3000
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Comma-separated allowlist for CORS (the Vite dev server by default)
CORS_ORIGINS=http://localhost:5173
# Defaults to true outside production; set explicitly to expose docs in prod
# SWAGGER_ENABLED=true
SHUTDOWN_TIMEOUT_MS=25000
# Readiness thresholds (memory heap MB / disk usage fraction)
HEALTH_MEM_HEAP_MB=512
HEALTH_DISK_PERCENT=0.9

# ----------------------------- mongo ----------------------------------------
MONGODB_URI=mongodb://localhost:27017/cvantage

# ----------------------------- auth ------------------------------------------
# ≥32 chars each. Dev defaults exist but are REJECTED in production.
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# COOKIE_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ------------------- oauth (optional — feature-flagged pairs) ----------------
# Provide BOTH id and secret to enable a provider; buttons appear automatically.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# Defaults to APP_BASE_URL; set when callbacks differ (e.g. tunnels)
# OAUTH_CALLBACK_BASE_URL=

# ----------------------------- crypto ----------------------------------------
# base64 of exactly 32 random bytes; encrypts provider API keys at rest.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Dev default exists but is REJECTED in production.
# MASTER_ENCRYPTION_KEY=

# ------------------------- first-admin seed (scripts) ------------------------
# Used by `yarn workspace @cvantage/server seed:admin` (issue #20) — not at boot.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ----------------------------- storage ---------------------------------------
# local | s3
STORAGE_DRIVER=local
# Created if missing; mount a volume here on Railway
UPLOAD_DIR=./uploads
# Required when STORAGE_DRIVER=s3 (any S3-compatible endpoint)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ------------------------------- llm -----------------------------------------
# openai | fake   (fake = deterministic fixtures for tests/e2e)
LLM_PROVIDER=openai
# Falls back to admin-managed models (Settings) when present; env is the fallback.
# OPENAI_API_KEY=
# Any OpenAI-compatible endpoint (OpenRouter etc.)
# OPENAI_BASE_URL=
LLM_PARSING_MODEL=gpt-4o-mini
LLM_ANALYSIS_MODEL=gpt-4o
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
LLM_USER_CONCURRENCY=2
# max_tokens per call, by usage
LLM_MAX_TOKENS_PARSING=8192
LLM_MAX_TOKENS_ANALYSIS=4096
# Background job workers per process (analyses, upload parses)
JOB_CONCURRENCY=2
# Server-sent events: heartbeat cadence + per-user stream cap
# Admin dashboard stats cache window (seconds)
ADMIN_STATS_CACHE_S=60
SSE_HEARTBEAT_MS=15000
SSE_MAX_CONNECTIONS_PER_USER=5

# ------------------------------- mail ----------------------------------------
# console | smtp   (console logs rendered emails — zero-setup local default)
MAIL_DRIVER=console
# Required when MAIL_DRIVER=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="CVantage <no-reply@example.com>"

# ----------------------------- throttling ------------------------------------
THROTTLE_TTL_S=60
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=10
THROTTLE_UPLOAD_LIMIT=10
THROTTLE_ANALYSIS_LIMIT=10
# Progressive login lockout: failures within window -> escalating blocks
LOCKOUT_MAX_FAILURES=5
LOCKOUT_WINDOW_S=900
LOCKOUT_BASE_BLOCK_S=60
LOCKOUT_MAX_BLOCK_S=3600

# ---------------------- observability (all optional) -------------------------
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cvantage-api
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
