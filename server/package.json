{
  "name": "@cvantage/server",
  "version": "0.1.0",
  "private": true,
  "description": "CVantage API server (NestJS + MongoDB)",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --max-warnings 0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest -c jest.e2e.config.cjs",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "seed:admin": "node dist/scripts/seed-admin.js",
    "db:indexes": "node dist/scripts/sync-indexes.js",
    "prebuild": "yarn workspace @cvantage/shared build",
    "pretest": "yarn workspace @cvantage/shared build",
    "pretypecheck": "yarn workspace @cvantage/shared build",
    "db:reconcile-counters": "node dist/scripts/reconcile-counters.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@cvantage/shared": "0.1.0",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/mongoose": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/swagger": "^11",
    "@nestjs/terminus": "^11",
    "@nestjs/throttler": "^6",
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "langchain": "^1.4.4",
    "mammoth": "^1.12.0",
    "mongoose": "^8",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.11",
    "pdf-parse": "1.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "word-extractor": "^1.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/word-extractor": "^1.0.6",
    "jest": "^30.4.2",
    "jszip": "^3.10.1",
    "mongodb-memory-server": "^11.2.0",
    "pdfkit": "^0.19.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11"
  }
}
